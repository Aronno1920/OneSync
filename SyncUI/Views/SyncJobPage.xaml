<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:SyncUI.ViewModels"
             xmlns:models="clr-namespace:SyncUI.Models"
             x:Class="SyncUI.Views.SyncJobPage"
             x:DataType="viewmodels:SyncJobViewModel"
             Title="{Binding IsNew, Converter={StaticResource BoolToTitleConverter}}">

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Frame Grid.Row="0"
               BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
               Padding="16"
               HasShadow="True">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text="←"
                        Command="{Binding CancelCommand}"
                        WidthRequest="40"
                        HeightRequest="40"
                        CornerRadius="20"
                        Padding="0"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="20"/>
                <Label Grid.Column="1"
                       Text="{Binding IsNew, Converter={StaticResource BoolToTitleConverter}}"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="White"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"/>
                <ActivityIndicator Grid.Column="2"
                                   IsRunning="{Binding IsLoading}"
                                   Color="White"
                                   VerticalOptions="Center"/>
            </Grid>
        </Frame>

        <!-- Form -->
        <ScrollView Grid.Row="1">
            <StackLayout Padding="16" Spacing="16">
                <!-- Job Name -->
                <Frame Padding="16" CornerRadius="12" HasShadow="True">
                    <StackLayout Spacing="8">
                        <Label Text="Job Name"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="Gray"/>
                        <Entry Text="{Binding Job.Name}"
                               Placeholder="Enter job name"
                               FontSize="16"/>
                    </StackLayout>
                </Frame>

                <!-- Source Path -->
                <Frame Padding="16" CornerRadius="12" HasShadow="True">
                    <StackLayout Spacing="8">
                        <Label Text="Source Path"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="Gray"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <Entry Grid.Column="0"
                                   Text="{Binding Job.SourcePath}"
                                   Placeholder="Select source folder"
                                   FontSize="14"
                                   IsReadOnly="True"/>
                            <Button Grid.Column="1"
                                    Text="📁"
                                    Command="{Binding BrowseSourceCommand}"
                                    WidthRequest="50"
                                    HeightRequest="40"
                                    CornerRadius="8"
                                    Padding="0"
                                    Margin="8,0,0,0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                    TextColor="White"/>
                        </Grid>
                    </StackLayout>
                </Frame>

                <!-- Destination Path -->
                <Frame Padding="16" CornerRadius="12" HasShadow="True">
                    <StackLayout Spacing="8">
                        <Label Text="Destination Path"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="Gray"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <Entry Grid.Column="0"
                                   Text="{Binding Job.DestinationPath}"
                                   Placeholder="Select destination folder"
                                   FontSize="14"
                                   IsReadOnly="True"/>
                            <Button Grid.Column="1"
                                    Text="📁"
                                    Command="{Binding BrowseDestinationCommand}"
                                    WidthRequest="50"
                                    HeightRequest="40"
                                    CornerRadius="8"
                                    Padding="0"
                                    Margin="8,0,0,0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                    TextColor="White"/>
                        </Grid>
                    </StackLayout>
                </Frame>

                <!-- Test Connection Button -->
                <Button Text="🔍 Test Connection"
                        Command="{Binding TestConnectionCommand}"
                        IsEnabled="{Binding IsTestingConnection, Converter={StaticResource InverseBoolConverter}}"
                        HeightRequest="50"
                        CornerRadius="25"
                        FontAttributes="Bold"
                        BackgroundColor="{AppThemeBinding Light=#FF9800, Dark=#F57C00}"
                        TextColor="White"
                        Margin="0,8"/>

                <!-- Validation Message -->
                <Frame Padding="12"
                       CornerRadius="8"
                       IsVisible="{Binding IsTestingConnection, Converter={StaticResource InverseBoolConverter}}"
                       BackgroundColor="{Binding IsValid, Converter={StaticResource BoolToValidationColorConverter}}">
                    <Label Text="{Binding ValidationMessage}"
                           FontSize="14"
                           TextColor="{Binding IsValid, Converter={StaticResource BoolToValidationTextColorConverter}}"/>
                </Frame>

                <!-- Sync Direction -->
                <Frame Padding="16" CornerRadius="12" HasShadow="True">
                    <StackLayout Spacing="8">
                        <Label Text="Sync Direction"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="Gray"/>
                        <Picker ItemsSource="{Binding AvailableDirections}"
                                SelectedItem="{Binding Job.Direction}"
                                Title="Select direction"
                                FontSize="16"/>
                    </StackLayout>
                </Frame>

                <!-- Sync Mode -->
                <Frame Padding="16" CornerRadius="12" HasShadow="True">
                    <StackLayout Spacing="8">
                        <Label Text="Sync Mode"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="Gray"/>
                        <Picker ItemsSource="{Binding AvailableModes}"
                                SelectedItem="{Binding Job.Mode}"
                                Title="Select mode"
                                FontSize="16"/>
                    </StackLayout>
                </Frame>

                <!-- Sync Interval -->
                <Frame Padding="16" CornerRadius="12" HasShadow="True">
                    <StackLayout Spacing="8">
                        <Label Text="Sync Interval"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="Gray"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <Slider Grid.Column="0"
                                    Value="{Binding Job.SyncInterval, Converter={StaticResource TimeSpanToMinutesConverter}}"
                                    Minimum="1"
                                    Maximum="60"
                                    MaximumTrackColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                    MinimumTrackColor="Gray"/>
                            <Label Grid.Column="1"
                                   Text="{Binding Job.SyncInterval, Converter={StaticResource TimeSpanToTextConverter}}"
                                   FontSize="14"
                                   WidthRequest="80"
                                   HorizontalTextAlignment="End"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </StackLayout>
                </Frame>

                <!-- Enable Job Toggle -->
                <Frame Padding="16" CornerRadius="12" HasShadow="True">
                    <Grid ColumnDefinitions="Auto,*">
                        <Switch Grid.Column="0"
                                IsToggled="{Binding Job.IsEnabled}"
                                OnColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                ThumbColor="White"
                                VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="Enable this job"
                               FontSize="16"
                               VerticalOptions="Center"
                               Margin="12,0,0,0"/>
                    </Grid>
                </Frame>

                <!-- Action Buttons -->
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      Margin="0,16,0,0">
                    <Button Grid.Column="0"
                            Text="Cancel"
                            Command="{Binding CancelCommand}"
                            HeightRequest="50"
                            CornerRadius="25"
                            FontAttributes="Bold"
                            BackgroundColor="Gray"
                            TextColor="White"/>
                    <Button Grid.Column="1"
                            Text="Save"
                            Command="{Binding SaveCommand}"
                            IsEnabled="{Binding IsValid}"
                            HeightRequest="50"
                            CornerRadius="25"
                            FontAttributes="Bold"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            TextColor="White"/>
                </Grid>
            </StackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
