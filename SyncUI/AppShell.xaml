<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:SyncUI.Views"
       x:Class="SyncUI.AppShell"
       Title="OneSync">

    <Shell.FlyoutHeader>
        <Grid BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
              HeightRequest="120">
            <Label Text="OneSync"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="White"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"/>
        </Grid>
    </Shell.FlyoutHeader>

    <FlyoutItem Title="Dashboard"
                Icon="dashboard.png">
        <ShellContent Title="Dashboard"
                      Route="MainPage"
                      ContentTemplate="{DataTemplate views:MainPage}"/>
    </FlyoutItem>

    <FlyoutItem Title="Jobs"
                Icon="jobs.png">
        <ShellContent Title="Jobs"
                      Route="SyncJobPage"
                      ContentTemplate="{DataTemplate views:SyncJobPage}"/>
    </FlyoutItem>

    <FlyoutItem Title="Files"
                Icon="files.png">
        <ShellContent Title="Files"
                      Route="FileListView"
                      ContentTemplate="{DataTemplate views:FileListView}"/>
    </FlyoutItem>

    <MenuItem Text="Settings"
              IconImageSource="settings.png"
              Command="{Binding SettingsCommand}"/>

    <MenuItem Text="About"
              IconImageSource="info.png"
              Command="{Binding AboutCommand}"/>

</Shell>
